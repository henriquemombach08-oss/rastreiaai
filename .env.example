# ============================================================
# Rastreaí — variáveis de ambiente
# Copie para .env.local e preencha os valores.
# ============================================================

# Supabase (público — pode ir para o client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — NUNCA expor no client, só em API routes (server-side)
SUPABASE_SERVICE_ROLE_KEY=

# URL pública da aplicação (usada em redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mapa: chave gratuita do MapTiler para tiles de produção.
# Sem ela, o app usa o OpenStreetMap público (ok p/ dev, não p/ produção em escala).
# Cobre o Brasil inteiro. Pegue em https://www.maptiler.com/ (Account → Keys).
NEXT_PUBLIC_MAPTILER_KEY=

# ------------------------------------------------------------
# Integração iFood (opcional — desligada por padrão no MVP)
# ------------------------------------------------------------
# Liga toda a integração (webhook + polling). Deixe false para o fluxo manual.
IFOOD_ENABLED=false

# Segredo do webhook do iFood (validação da assinatura HMAC)
IFOOD_WEBHOOK_SECRET=

# Credenciais OAuth da Merchant API
IFOOD_CLIENT_ID=
IFOOD_CLIENT_SECRET=

# Base URL da Merchant API (produção por padrão)
IFOOD_BASE_URL=https://merchant-api.ifood.com.br

# Segredo que protege a rota de polling /api/ifood/poll (chamada por cron)
CRON_SECRET=
